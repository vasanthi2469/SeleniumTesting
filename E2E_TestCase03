package TestCases;

import java.time.Duration;  
import org.openqa.selenium.By;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.support.ui.ExpectedConditions;

public class TestCase_03 {

    public static void main(String[] args) {

        ChromeDriver driver = new ChromeDriver();
        driver.manage().window().maximize();

        WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(15));

        // Step 1: Open OrangeHRM login page
        driver.get("https://opensource-demo.orangehrmlive.com/web/index.php/auth/login");

        // Step 2: Wait for username field
        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.name("username")));

        // Step 3: Enter credentials
        driver.findElement(By.name("username")).sendKeys("Admin");
        driver.findElement(By.name("password")).sendKeys("admin123");

        // Step 4: Click Login
        driver.findElement(By.cssSelector("button[type='submit']")).click();

        // Step 5: Verify Dashboard page loaded
        WebElement dashboardHeader = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//h6[text()='Dashboard']")));

        if (dashboardHeader.isDisplayed()) {
            System.out.println("Login successful");
            System.out.println("Dashboard visible");
        } else {
            System.out.println("Dashboard not visible");
        }

        // Step 6: Click profile icon
        WebElement profileIcon = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.cssSelector(".oxd-userdropdown-name")));
        profileIcon.click();

        // Step 7: Click Logout
        wait.until(ExpectedConditions.elementToBeClickable(
                By.xpath("//a[text()='Logout']"))).click();

        // Step 8: Verify redirected to login page
        wait.until(ExpectedConditions.visibilityOfElementLocated(
                By.name("username")));

        if (driver.getCurrentUrl().contains("login")) {
            System.out.println("Logout successful");
            System.out.println("Redirected back to login page");
        } else {
            System.out.println("Logout failed");
        }

        driver.quit();
    }
}
